  "tokenColors": [
    {
      "name": "Normal / Default text",
      "scope": [""],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#875f5f" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.language"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "markup.inline.raw"
      ],
      "settings": { "foreground": "#d7af87" }
    },
    {
      "name": "Character (links to Constant)",
      "scope": ["constant.character"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#5f87af" }
    },
    {
      "name": "Boolean (links to Number)",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#5f87af" }
    },
    {
      "name": "Float (links to Number)",
      "scope": ["constant.numeric.float"],
      "settings": { "foreground": "#5f87af" }
    },
    {
      "name": "Identifier",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "support.variable"
      ],
      "settings": { "foreground": "#a8a8a8" }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#ffd787" }
    },
    {
      "name": "Statement / Keyword (conditional, repeat, label, keyword, exception)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.exception",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#d75f00" }
    },
    {
      "name": "PreProc (include, define, macro, precondit)",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "keyword.import",
        "entity.name.namespace"
      ],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "Special / Tag / SpecialChar / Debug",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "support.class",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "Type (StorageClass, Structure, Typedef)",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.alias",
        "entity.name.type.enum",
        "support.type"
      ],
      "settings": { "foreground": "#ffd7af" }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": { "foreground": "#d7875f" }
    },
    {
      "name": "Delimiter",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": { "foreground": "#d7875f" }
    },
    {
      "name": "Todo",
      "scope": ["comment.line keyword.codetag.todo", "keyword.codetag"],
      "settings": { "foreground": "#ffffff", "fontStyle": "bold" }
    },
    {
      "name": "Underlined",
      "scope": ["markup.underline", "constant.other.color"],
      "settings": { "foreground": "#ffd75f" }
    },
    {
      "name": "Error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ffffd7", "background": "#870000" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#875f5f", "fontStyle": "strikethrough" }
    },
    {
      "name": "Title",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#ffffd7", "fontStyle": "bold" }
    },

    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#d75f00" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "HTML Tag Punctuation",
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#d7875f" }
    },

    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "CSS Value",
      "scope": ["meta.property-value", "support.constant.property-value"],
      "settings": { "foreground": "#ffd7af" }
    },
    {
      "name": "CSS Units",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#5f87af" }
    },

    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#ffaf5f" }
    },

    {
      "name": "JavaScript Object Key",
      "scope": [
        "meta.object-literal.key",
        "string.quoted.double.js meta.objectliteral"
      ],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "JavaScript Function Key (dead/error-like)",
      "scope": ["meta.function.expression variable.other.object.property"],
      "settings": { "foreground": "#870000" }
    },

    {
      "name": "Markdown URL",
      "scope": ["markup.underline.link", "string.other.link.description"],
      "settings": { "foreground": "#875f5f" }
    },
    {
      "name": "Markdown Link Text Delimiter",
      "scope": [
        "punctuation.definition.link",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": { "foreground": "#d7875f" }
    },
    {
      "name": "Markdown Code Block",
      "scope": ["markup.fenced_code", "markup.raw.block"],
      "settings": { "foreground": "#d7af87" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ffffff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d7875f" }
    },
    {
      "name": "Markup Diff Added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#ffffd7" }
    },
    {
      "name": "Markup Diff Removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#870000" }
    },
    {
      "name": "Markup Diff Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#d7875f" }
    },

    {
      "name": "Python Decorator / Special",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#ffaf5f" }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": { "foreground": "#d7875f" }
    },
    {
      "name": "this / self language variable",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#d7875f" }
    },

    {
      "name": "Rust Lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "storage.modifier.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": { "foreground": "#5f87af" }
    },
    {
      "name": "Rust Macros",
      "scope": ["support.macro.rust", "entity.name.function.macro.rust"],
      "settings": { "foreground": "#ffaf5f" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":         "#ffffff",
    "class":             { "foreground": "#ffd7af" },
    "interface":         "#ffd7af",
    "enum":              "#ffd7af",
    "enumMember":        "#ffffff",
    "type":              "#ffd7af",
    "typeParameter":     { "foreground": "#5f87af" },
    "function":          "#ffd787",
    "method":            "#ffd787",
    "macro":             "#ffaf5f",
    "decorator":         "#ffaf5f",
    "variable":          "#a8a8a8",
    "variable.readonly": "#ffffff",
    "parameter":         "#a8a8a8",
    "property":          "#a8a8a8",
    "keyword":           "#d75f00",
    "modifier":          "#d75f00",
    "comment":           "#875f5f",
    "string":            "#d7af87",
    "number":            "#5f87af",
    "boolean":           "#5f87af",
    "operator":          "#d7875f",
    "selfKeyword":       "#d7875f",
    "lifetime":          "#5f87af"
  }
}
